# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Quotation-Invoice API"
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# Replace with your production PostgreSQL URL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quotation_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Replace localhost with your production frontend domain
ALLOWED_ORIGINS=["https://your-app.example.com"]

# ── Company identity (appears on PDF letterhead) ──────────────────────────────
COMPANY_NAME="Kytos Arabia"
COMPANY_ADDRESS="P.O. BOX 374, AL JUBAIL (Support Industries III) - 31961"
COMPANY_WEBSITE=www.sinanakh.com
COMPANY_PHONE=013-350-5200
COMPANY_FAX=013-362-4886
COMPANY_CONTACT_NAME=Mohammed Sarwar
COMPANY_DIRECT_LINE=013-350-5241
COMPANY_LOGO_PATH=/absolute/path/to/logo.jpg   # leave empty to use text logo

# ── SMTP (Gmail example — use an App Password, not your account password) ─────
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
